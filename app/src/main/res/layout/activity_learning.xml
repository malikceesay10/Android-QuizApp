<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_learning_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F0F2F5"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        android:visibility="visible" />

    <LinearLayout
        android:id="@+id/layout_single_question"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_question"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:layout_marginBottom="24dp"
            android:gravity="center" />

        <Button android:id="@+id/btn_optionA" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btn_optionB" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btn_optionC" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp"/>
        <Button android:id="@+id/btn_optionD" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btn_back_to_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Zurück zur Liste"
            android:backgroundTint="#808080" />
    </LinearLayout>
</LinearLayout>